{
  "train_batch_size": 8,

  "train_micro_batch_size_per_gpu": 8,

  "gradient_accumulation_steps": 1,

  "optimizer": {
    "type": "AdamW",
    "params": {
      "lr": 3e-5
    }
  },

  "fp16": {
    "enabled": true
  },

  "zero_optimization": {
    "stage": 0,
    "allgather_partitions": true,
    "reduce_scatter": true
  }
}